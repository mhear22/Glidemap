{
  "name": "glidemap",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --build",
    "typecheck:watch": "tsc --build --watch",
    "typecheck:adminapp": "vue-tsc --project tsconfig.adminapp.json",
    "typecheck:webapp": "vue-tsc --project tsconfig.webapp.json",
    "docker": "node --import tsx scripts/docker.ts",
    "docker:deploy": "node --import tsx scripts/docker-deploy.ts",
    "install:browsers": "playwright install chromium",
    "build:renderer": "esbuild web/renderer.ts --outfile=web/renderer.js --format=esm --target=es2022",
    "build:webapp": "vite build --config vite.config.ts",
    "build:admin": "vite build --config vite.admin.config.ts",
    "dev:webapp": "vite --config vite.config.ts",
    "dev:admin": "vite --config vite.admin.config.ts",
    "dev:server": "node --import tsx scripts/dev-server.ts",
    "dev": "npm run build:renderer && node --import tsx scripts/dev.ts",
    "serve": "npm run build:renderer && node --import tsx server/index.ts",
    "render": "node --import tsx scripts/render.ts --config ./routes.json",
    "render:route": "node --import tsx scripts/render.ts",
    "test": "node --import tsx --test tests/*.test.ts"
  },
  "dependencies": {
    "maplibre-gl": "^5.3.0",
    "playwright": "1.60.0",
    "vue": "^3.5.22"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@vitejs/plugin-vue": "^6.0.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.16",
    "vue-tsc": "^3.2.6"
  }
}

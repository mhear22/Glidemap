{
  "extends": "./tsconfig.node.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": false,
    "sourceMap": false
  },
  "include": [
    "server/**/*.ts",
    "lib/**/*.ts",
    "types/**/*.ts",
    "branding.ts"
  ],
  "exclude": ["node_modules", "tests", "scripts", "webapp", "web", "adminapp"]
}
